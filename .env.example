# ============================================================================
# RustAssistant .env Configuration
# ============================================================================
# Copy this file to `.env` (in the same folder as docker-compose.rustassistant.yml)
# Then run: docker compose -f docker-compose.rustassistant.yml up -d

# ────────────────────────────────────────────────────────────────────────────
# REQUIRED SECRETS (CHANGE THESE!)
# ────────────────────────────────────────────────────────────────────────────
XAI_API_KEY=sk-your-xai-api-key-here
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Redis password (must match docker-compose)
REDIS_PASSWORD=SuperSecretPassword123!ChangeMeNow

# ────────────────────────────────────────────────────────────────────────────
# Server & Logging
# ────────────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
RUST_LOG=info,rustassistant=debug

# ────────────────────────────────────────────────────────────────────────────
# AI Providers & Models
# ────────────────────────────────────────────────────────────────────────────
XAI_BASE_URL=https://api.x.ai/v1
REMOTE_MODEL=grok-2-latest
XAI_MODEL=grok-4-1-fast-reasoning        # optional override
XAI_MAX_TOKENS=4096
XAI_TEMPERATURE=0.3

# Local Ollama (used inside Docker network)
OLLAMA_BASE_URL=http://ollama:11434
LOCAL_MODEL=qwen2.5-coder:7b
FORCE_REMOTE_MODEL=false

# ────────────────────────────────────────────────────────────────────────────
# GitHub Integration
# ────────────────────────────────────────────────────────────────────────────
GITHUB_OWNER=your-github-username        # change to your GitHub username
GITHUB_BASE_URL=https://api.github.com

# ────────────────────────────────────────────────────────────────────────────
# Paths & Storage
# ────────────────────────────────────────────────────────────────────────────
# Where your repos live on your host machine (change this!)
REPOS_BASE_PATH=/home/jordan/github/

# Inside container paths (do NOT change these)
DATABASE_URL=sqlite:/app/data/rustassistant.db
REPOS_DIR=/app/repos
DATA_DIR=/app/data

# ────────────────────────────────────────────────────────────────────────────
# Redis & Caching
# ────────────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_PREFIX=rustassistant

# ────────────────────────────────────────────────────────────────────────────
# Background Services & Features
# ────────────────────────────────────────────────────────────────────────────
REPO_SYNC_INTERVAL_SECS=300
AUTO_SCAN_ENABLED=true
AUTO_SCAN_INTERVAL=60
AUTO_SCAN_MAX_CONCURRENT=2

# ────────────────────────────────────────────────────────────────────────────
# LLM Budget & Cost Control (optional)
# ────────────────────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=5.00
WARN_AT_PERCENT=80
BLOCK_ON_EXCEED=true

# ────────────────────────────────────────────────────────────────────────────
# Analysis Settings (optional)
# ────────────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=1000000
INCLUDE_TESTS=true
PARALLEL_JOBS=4

# ────────────────────────────────────────────────────────────────────────────
# Legacy / Future-proof vars (you can delete these if unused)
# ────────────────────────────────────────────────────────────────────────────
# VECTOR_DIM=1536
# CHUNK_SIZE=512
# WORKSPACE_DIR=data/workspaces
# ENABLE_WEB_UI=true
# ENABLE_AUTO_ANALYSIS=false
# ENABLE_GITHUB_SYNC=false
