# ============================================================================
# Rustassistant Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# XAI API Configuration (Grok 4.1)
# ----------------------------------------------------------------------------
XAI_API_KEY=xai-your-api-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning
XAI_MAX_TOKENS=4096
XAI_TEMPERATURE=0.3

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=3000
RUST_LOG=info,devflow=debug

# ----------------------------------------------------------------------------
# GitHub Integration (Optional)
# ----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_BASE_URL=https://api.github.com

# ----------------------------------------------------------------------------
# Database Configuration (Future: PostgreSQL/SQLite)
# ----------------------------------------------------------------------------
DATABASE_URL=sqlite://data/devflow.db
# DATABASE_URL=postgresql://user:password@localhost:5432/devflow

# ----------------------------------------------------------------------------
# Storage Paths
# ----------------------------------------------------------------------------
DATA_DIR=./data
REPOS_DIR=./data/repos
VECTORS_DIR=./data/vectors
NOTES_DIR=./data/notes
CACHE_DIR=./data/cache

# ----------------------------------------------------------------------------
# LLM Budget & Cost Control
# ----------------------------------------------------------------------------
DAILY_BUDGET_USD=5.00
WARN_AT_PERCENT=80
BLOCK_ON_EXCEED=true

# ----------------------------------------------------------------------------
# Analysis Configuration
# ----------------------------------------------------------------------------
MAX_FILE_SIZE_BYTES=1000000
INCLUDE_TESTS=true
PARALLEL_JOBS=4

# ----------------------------------------------------------------------------
# Vector Storage Configuration
# ----------------------------------------------------------------------------
VECTOR_DIM=1536
CHUNK_SIZE=512
OVERLAP=50
EMBEDDING_BATCH_SIZE=100

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_WEB_UI=true
ENABLE_AUTO_ANALYSIS=false
ENABLE_GITHUB_SYNC=false

# ----------------------------------------------------------------------------
# Local Model (Ollama) + Model Router
# ----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5-coder:7b
REMOTE_MODEL=grok-2-latest
# Set to true to force all tasks through the remote model (debug/testing)
FORCE_REMOTE_MODEL=false

# ----------------------------------------------------------------------------
# Repo Sync Service
# ----------------------------------------------------------------------------
# How often the background SyncScheduler runs (seconds)
REPO_SYNC_INTERVAL_SECS=300
# Base path on the host where repos are mounted (used by docker-compose)
REPOS_BASE_PATH=/home/jordan/repos

# ----------------------------------------------------------------------------
# Redis (for response caching — used by docker-compose.rustassistant.yml)
# ----------------------------------------------------------------------------
REDIS_URL=redis://:rustassist-change-me@localhost:6379
REDIS_PASSWORD=rustassist-change-me
CACHE_ENABLED=true
CACHE_PREFIX=rustassistant:

# ----------------------------------------------------------------------------
# Workspace (for web_api.rs pipeline dispatch)
# ----------------------------------------------------------------------------
WORKSPACE_DIR=data/workspaces
