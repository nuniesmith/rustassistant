# .env.rustassistant
# Copy to .env and fill in your secrets
# cp .env.rustassistant .env

# ── Required ────────────────────────────────────────────────────────────────
XAI_API_KEY=xai-your-key-here
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=nuniesmith

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=rustassist-change-me

# ── Repos ───────────────────────────────────────────────────────────────────
# Path on your HOST machine where all repos live
# These get mounted into the container at /repos/
REPOS_BASE_PATH=/home/jordan/repos

# ── Models ──────────────────────────────────────────────────────────────────
LOCAL_MODEL=qwen2.5-coder:7b
REMOTE_MODEL=grok-2-latest
FORCE_REMOTE_MODEL=false

# ── Sync ────────────────────────────────────────────────────────────────────
REPO_SYNC_INTERVAL_SECS=300
